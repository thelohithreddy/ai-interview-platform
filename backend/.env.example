PORT=5001
BACKEND_URL=http://127.0.0.1:5001
FRONTEND_URL=http://localhost:5173
OAUTH_STATE_SECRET=change-this-to-a-long-random-string

# Google — https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://127.0.0.1:5001/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub — https://github.com/settings/developers
# Authorization callback URL: http://127.0.0.1:5001/api/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Apple — https://developer.apple.com/account/resources/identifiers/list/serviceId
# Return URL: http://127.0.0.1:5001/api/auth/apple/callback
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
